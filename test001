let n = 5;

// Upper half
for (let i = 1; i <= n; i++) {
    let row = "";

    // Leading spaces
    for (let j = i; j < n; j++) {
        row += " ";
    }

    // Hollow part
    for (let j = 1; j <= 2 * i - 1; j++) {
        if (j === 1 || j === 2 * i - 1) {
            row += "*";
        } else {
            row += " ";
        }
    }

    console.log(row);
}

// Lower half
for (let i = n - 1; i >= 1; i--) {
    let row = "";

    // Leading spaces
    for (let j = n; j > i; j--) {
        row += " ";
    }

    // Hollow part
    for (let j = 1; j <= 2 * i - 1; j++) {
        if (j === 1 || j === 2 * i - 1) {
            row += "*";
        } else {
            row += " ";
        }
    }

    console.log(row);
}
